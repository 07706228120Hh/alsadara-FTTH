# ============================================
# Sadara Platform - Environment Variables
# ============================================
# انسخ هذا الملف إلى .env.local وأضف القيم الحقيقية
# ⚠️ لا ترفع .env.local إلى Git أبداً!
# ============================================

# مفتاح API الداخلي للاتصال بـ Sadara Backend
SADARA_INTERNAL_API_KEY=your-secure-api-key-here

# مفتاح Google Sheets API
GOOGLE_SHEETS_API_KEY=your-google-sheets-api-key

# مفتاح Google Drive API  
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key

# ============================================
# إعدادات الخادم (اختياري)
# ============================================

# رابط API للإنتاج
# API_BASE_URL=https://api.ramzalsadara.tech/api

# ============================================
# Firebase (اختياري - إذا كنت تستخدم Firebase)
# ============================================

# FIREBASE_API_KEY=your-firebase-api-key
# FIREBASE_PROJECT_ID=your-project-id
