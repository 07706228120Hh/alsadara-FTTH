      "id": "ar-get-phone",
      "name": "Get Phone",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2200, 400],
      "retryOnFail": true,
      "waitBetweenTries": 2000,
      "maxTries": 2,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const store = $getWorkflowStaticData('global');\nif (!store.ready) store.ready = [];\nif (!store.stats) store.stats = { total: 0, withPhone: 0, noPhone: 0, sent: 0, failed: 0 };\nconst prev = $('Split For Phones').first().json;\nconst phoneData = $input.first().json;\nconst phone = phoneData.model?.primaryContact?.mobile || '';\nstore.stats.total++;\nlet clean = phone.replace(/[^\\d]/g, '');\nif (clean.startsWith('0')) clean = '964' + clean.substring(1);\nelse if (!clean.startsWith('964')) clean = '964' + clean;\nconst valid = /^964\\d{9,12}$/.test(clean) && clean.length >= 12;\nif (valid) { store.stats.withPhone++; store.ready.push({ phone: clean, name: prev.customer_name || '', expires: prev.expires || '', config: prev.config }); }\nelse { store.stats.noPhone++; }\nreturn [{ json: { processed: store.stats.total } }];"
      },
      "id": "ar-store-phone",
      "name": "Store Phone",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2420, 400]
    },
    {
      "parameters": {
        "jsCode": "const store = $getWorkflowStaticData('global');\nconst ready = store.ready || [];\nconst stats = store.stats || {};\nif (ready.length === 0) return [];\nconst result = ready.map(r => ({ json: r }));\nstore.ready = [];\nreturn result;"
      },
      "id": "ar-output",
      "name": "Output Ready",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2200, 600],
      "alwaysOutputData": true
    },
    {
      "parameters": { "batchSize": 1, "options": {} },
      "id": "ar-split-send",
      "name": "Split For Send",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 2,
      "position": [2420, 600]
    },
    {
      "parameters": {
        "jsCode": "const item = $json;\nconst config = item.config || $('Configuration').first().json;\nlet endDate = '';\ntry { const d = new Date(item.expires); endDate = d.toISOString().split('T')[0]; } catch(e) { endDate = item.expires || ''; }\nreturn [{ json: { phone: item.phone, name: item.name, endDate: endDate, contactNumbers: config.contactNumbers || '07705210210' } }];"
      },
      "id": "ar-prepare-msg",
      "name": "Prepare Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, 600]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{ $('Configuration').first().json.phoneNumberId || '' }}/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "whatsAppApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $json.phone }}\",\n  \"type\": \"template\",\n  \"template\": {\n    \"name\": \"sadara_reminder\",\n    \"language\": { \"code\": \"ar\" },\n    \"components\": [\n      {\n        \"type\": \"header\",\n        \"parameters\": [{ \"type\": \"location\", \"location\": { \"latitude\": \"33.3574242\", \"longitude\": \"44.4413559\", \"name\": \"\\u0634\\u0631\\u0643\\u0629 \\u0627\\u0644\\u0635\\u062f\\u0627\\u0631\\u0629\", \"address\": \"\\u0627\\u0644\\u0645\\u0634\\u063a\\u0644 \\u0627\\u0644\\u0631\\u0633\\u0645\\u064a\" } }]\n      },\n      {\n        \"type\": \"body\",\n        \"parameters\": [\n          { \"type\": \"text\", \"text\": \"{{ $json.name }}\" },\n          { \"type\": \"text\", \"text\": \"{{ $json.endDate }}\" },\n          { \"type\": \"text\", \"text\": \"{{ $json.contactNumbers }}\" }\n        ]\n      }\n    ]\n  }\n}",
        "options": { "timeout": 15000 }
      },
      "id": "ar-send",
      "name": "Send WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2860, 600],
      "retryOnFail": true,
      "waitBetweenTries": 3000,
      "maxTries": 2,
      "credentials": { "whatsAppApi": { "id": "EzucHolIyaZJI1AD", "name": "WhatsApp account" } },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const store = $getWorkflowStaticData('global');\nif (!store.stats) store.stats = { total: 0, withPhone: 0, noPhone: 0, sent: 0, failed: 0 };\nconst r = $json;\nconst prev = $('Prepare Message').first().json;\nif (r.messages && r.messages.length > 0) { store.stats.sent++; } else { store.stats.failed++; }\nreturn [{ json: { sent: !!(r.messages && r.messages.length > 0), phone: prev.phone, name: prev.name } }];"
      },
      "id": "ar-track",
      "name": "Track Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3080, 600]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst prev = $('Prepare Message').first().json;\nconst msg = '\\u0639\\u0632\\u064a\\u0632\\u064a \\u0627\\u0644\\u0645\\u0634\\u062a\\u0631\\u0643 ' + prev.name + '\\n\\u0627\\u0634\\u062a\\u0631\\u0627\\u0643\\u0643 \\u0633\\u064a\\u0646\\u062a\\u0647\\u064a \\u0628\\u062a\\u0627\\u0631\\u064a\\u062e ' + prev.endDate;\nreturn [{ json: { phone: prev.phone, apiBody: { message: msg, type: 'template' } } }];"
      },
      "id": "ar-prepare-api",
      "name": "Prepare API Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3200, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.ramzalsadara.tech/api/whatsapp/conversations/{{ $json.phone }}/messages",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "X-Api-Key", "value": "={{ $('Configuration').first().json.apiKey }}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.apiBody) }}",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "ar-save-api",
      "name": "Save To API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3320, 500]
    },
    {
      "parameters": { "amount": 1.5, "unit": "seconds" },
      "id": "ar-delay",
      "name": "Delay",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [3320, 600],
      "webhookId": "ar-delay"
    },
    {
      "parameters": {
        "jsCode": "const store = $getWorkflowStaticData('global');\nconst stats = store.stats || { total: 0, withPhone: 0, noPhone: 0, sent: 0, failed: 0 };\nconst config = $('Configuration').first().json;\nconst now = new Date();\nconst bNow = new Date(now.getTime() + 180 * 60000);\nconst time = String(bNow.getHours()).padStart(2,'0') + ':' + String(bNow.getMinutes()).padStart(2,'0');\nconst date = bNow.toISOString().split('T')[0];\nstore.stats = null;\nreturn [{ json: { total: stats.total, sent: stats.sent, failed: stats.failed, withPhone: stats.withPhone, noPhone: stats.noPhone, time: time, date: date, days: Number(config.days || 0), apiKey: config.apiKey, managerPhone: config.managerPhone, phoneNumberId: config.phoneNumberId, message: '\\ud83d\\udcca *' + '\\u062a\\u0642\\u0631\\u064a\\u0631 \\u0627\\u0644\\u062a\\u0630\\u0643\\u064a\\u0631' + '*\\n\\n' + date + ' - ' + time + '\\n\\n\\u0627\\u0644\\u0645\\u0634\\u062a\\u0631\\u0643\\u064a\\u0646: *' + stats.total + '*\\n\\u0623\\u0631\\u0633\\u0644: *' + stats.sent + '*\\n\\u0641\\u0634\\u0644: *' + stats.failed + '*' } }];"
      },
      "id": "ar-report",
      "name": "Build Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, 800]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.ramzalsadara.tech/api/reminders/logs",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "X-Api-Key", "value": "={{ $json.apiKey }}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ days: $json.days, total: $json.total, sent: $json.sent, failed: $json.failed, isManual: false }) }}",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "ar-save-log",
      "name": "Save Execution Log",
      "type": "n8n-nodes-base.httpRequest",
