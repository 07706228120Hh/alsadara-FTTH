      "id": "ar-check-login",
      "name": "Login OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [680, 560]
    },
    {
      "parameters": {
        "jsCode": "const config = $('Configuration').first().json;\nconst token = $json.access_token;\nconst days = Number(config.days || 0);\nconst now = new Date();\nconst baghdadOffset = 3 * 60;\nconst baghdadNow = new Date(now.getTime() + (baghdadOffset + now.getTimezoneOffset()) * 60000);\nconst target = new Date(baghdadNow);\ntarget.setDate(target.getDate() + days);\nconst fromBaghdad = new Date(target.getFullYear(), target.getMonth(), target.getDate(), 0, 0, 0);\nconst toBaghdad = new Date(target.getFullYear(), target.getMonth(), target.getDate(), 23, 59, 59);\nconst fromUTC = new Date(fromBaghdad.getTime() - baghdadOffset * 60000).toISOString();\nconst toUTC = new Date(toBaghdad.getTime() - baghdadOffset * 60000).toISOString();\n\n// Initialize pagination in static data\nconst store = $getWorkflowStaticData('global');\nstore.allSubs = [];\nstore.pageNum = 1;\n\nreturn [{ json: { access_token: token, fromExpirationDate: fromUTC, toExpirationDate: toUTC, pageNumber: 1, pageSize: 150, config: config } }];"
      },
      "id": "ar-dates",
      "name": "Calculate Dates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 400]
    },
    {
      "parameters": {
        "url": "https://admin.ftth.iq/api/subscriptions",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "sortCriteria.property", "value": "expires" },
            { "name": "sortCriteria.direction", "value": "asc" },
            { "name": "status", "value": "Active" },
            { "name": "hierarchyLevel", "value": "0" },
            { "name": "fromExpirationDate", "value": "={{ $json.fromExpirationDate }}" },
            { "name": "toExpirationDate", "value": "={{ $json.toExpirationDate }}" },
            { "name": "pageSize", "value": "={{ $json.pageSize }}" },
            { "name": "pageNumber", "value": "={{ $json.pageNumber }}" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Accept", "value": "application/json" },
            { "name": "Authorization", "value": "={{ 'Bearer ' + $json.access_token }}" },
            { "name": "x-client-app", "value": "53d57a7f-3f89-4e9d-873b-3d071bc6dd9f" },
            { "name": "x-user-role", "value": "0" }
          ]
        },
        "options": {}
      },
      "id": "ar-get-subs",
      "name": "Get Subscriptions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1120, 400],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const store = $getWorkflowStaticData('global');\nconst data = $input.first().json;\nconst items = data.items || [];\nconst calcData = $('Calculate Dates').first().json;\nconst token = calcData.access_token;\nconst config = calcData.config;\n\n// Collect subscribers from this page\nfor (const row of items) {\n  store.allSubs.push({\n    customer_id: row.customer?.id,\n    customer_name: row.customer?.displayValue,\n    service_name: row.services?.[0]?.displayValue || row.bundle?.displayValue,\n    zone_name: row.zone?.displayValue,\n    expires: row.expires,\n    access_token: token,\n    config: config\n  });\n}\n\nstore.pageNum = (store.pageNum || 1) + 1;\nconst hasMore = items.length >= 150;\n\nreturn [{ json: { hasMore: hasMore, collected: store.allSubs.length, page: store.pageNum - 1 } }];"
      },
      "id": "ar-collect",
      "name": "Collect Page",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 2 },
          "conditions": [{ "id": "check-more", "leftValue": "={{ $json.hasMore }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }],
          "combinator": "and"
        },
        "looseTypeValidation": true,
        "options": {}
      },
      "id": "ar-has-more",
      "name": "Has More?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1540, 400]
    },
    {
      "parameters": {
        "jsCode": "const store = $getWorkflowStaticData('global');\nconst calcData = $('Calculate Dates').first().json;\n\nreturn [{ json: {\n  access_token: calcData.access_token,\n  fromExpirationDate: calcData.fromExpirationDate,\n  toExpirationDate: calcData.toExpirationDate,\n  pageNumber: store.pageNum || 2,\n  pageSize: 150,\n  config: calcData.config\n} }];"
      },
      "id": "ar-next-page",
      "name": "Next Page",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, 560]
    },
    {
      "parameters": {
        "jsCode": "const store = $getWorkflowStaticData('global');\nconst allSubs = store.allSubs || [];\n\n// Reset pagination state\nstore.allSubs = [];\nstore.pageNum = 1;\n\nif (allSubs.length === 0) return [];\nreturn allSubs.map(s => ({ json: s }));"
      },
