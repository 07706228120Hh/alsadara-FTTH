# API Configuration Settings
# نسخ هذا الملف إلى .env وملء القيم

# إعدادات API الأساسية
FTTH_API_BASE_URL=https://api.ftth.iq
FTTH_API_VERSION=v1

# إعدادات المصادقة (يملأها العميل)
CLIENT_ID=
CLIENT_SECRET=
API_KEY=

# إعدادات قاعدة البيانات المحلية (اختياري)
LOCAL_DB_PATH=data/app_data.db
ENABLE_LOCAL_CACHE=true

# إعدادات Google Sheets (اختياري)
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_PATH=assets/service_account.json

# إعدادات التطبيق
APP_NAME=Alsadara
APP_VERSION=1.1.6
COMPANY_NAME=
COMPANY_LOGO_PATH=assets/company_logo.png

# إعدادات الأمان
ENABLE_ENCRYPTION=true
ENABLE_AUTO_BACKUP=true
BACKUP_INTERVAL_HOURS=24

# إعدادات الواجهة
DEFAULT_LANGUAGE=ar
DEFAULT_THEME=light
ENABLE_NOTIFICATIONS=true

# إعدادات التحديث
AUTO_CHECK_UPDATES=true
UPDATE_SERVER_URL=
ALLOW_BETA_UPDATES=false

# إعدادات السجلات
LOG_LEVEL=INFO
LOG_MAX_FILES=10
LOG_MAX_SIZE_MB=50

# إعدادات الشبكة
CONNECTION_TIMEOUT_SECONDS=30
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=2
