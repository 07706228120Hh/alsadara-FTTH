{
  "_description": "نموذج ملف الأسرار - انسخه إلى .secrets.json واملأ البيانات",
  "_instructions": "cp .secrets.example.json .secrets.json",
  
  "project": {
    "projectId": "your-firebase-project-id",
    "projectNumber": "YOUR_PROJECT_NUMBER",
    "webApiKey": "YOUR_WEB_API_KEY"
  },
  
  "serviceAccount": {
    "_note": "قم بتنزيل ملف Service Account من Firebase Console > Project Settings > Service Accounts",
    "type": "service_account",
    "project_id": "your-project-id",
    "private_key_id": "YOUR_PRIVATE_KEY_ID",
    "private_key": "-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n",
    "client_email": "firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com",
    "client_id": "YOUR_CLIENT_ID",
    "auth_uri": "https://accounts.google.com/o/oauth2/auth",
    "token_uri": "https://oauth2.googleapis.com/token"
  },
  
  "android": {
    "packageName": "com.yourcompany.app",
    "sha1": "YOUR_SHA1_FINGERPRINT",
    "sha256": "YOUR_SHA256_FINGERPRINT"
  },
  
  "ios": {
    "bundleId": "com.yourcompany.app",
    "appStoreId": ""
  },
  
  "web": {
    "apiKey": "YOUR_WEB_API_KEY",
    "authDomain": "your-project.firebaseapp.com",
    "databaseURL": "https://your-project.firebaseio.com",
    "storageBucket": "your-project.appspot.com",
    "messagingSenderId": "YOUR_SENDER_ID",
    "appId": "YOUR_APP_ID",
    "measurementId": "YOUR_MEASUREMENT_ID"
  },
  
  "cloudMessaging": {
    "serverKey": "YOUR_FCM_SERVER_KEY",
    "vapidKey": "YOUR_VAPID_KEY"
  },
  
  "testAccounts": {
    "phone": "+1234567890",
    "verificationCode": "123456"
  }
}
